# ---------------------------------------------------------------------------
# Kidzopedia frontend environment variables
# Copy this file to `.env` for local dev, and set the same keys in
# Vercel → Project Settings → Environment Variables for production.
#
# NOTE: Vite inlines VITE_* vars at BUILD time. They ship to the browser,
# so only put public values here (the Supabase anon/publishable key is
# safe to expose; never put the service_role key in any VITE_* var).
# ---------------------------------------------------------------------------

# Public URL of your Supabase API gateway (Kong). Must be reachable from the
# end-user's browser. For a public Vercel deployment this must be a public
# HTTPS endpoint — NOT a LAN address like http://192.168.x.x.
VITE_SUPABASE_URL="https://your-supabase-host"

# Supabase anon / publishable key (public, client-side).
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Informational only (self-hosted project name).
VITE_SUPABASE_PROJECT_ID="kidzo"

# ---------------------------------------------------------------------------
# Error monitoring — self-hosted GlitchTip (Sentry-compatible).
# The DSN is PUBLIC/client-safe (it only allows sending events, not reading).
# Set the same value in Vercel → Project Settings → Environment Variables.
# Leave empty to disable error reporting (e.g. local dev).
# ---------------------------------------------------------------------------
VITE_GLITCHTIP_DSN="https://17eef314ba79447582baf22eaacb52b6@error-kidzo.unimisk.com/1"

# Optional: fraction of transactions sampled for performance (0.0–1.0).
VITE_GLITCHTIP_TRACES_SAMPLE_RATE="0.2"
